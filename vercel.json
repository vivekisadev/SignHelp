{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/model.json",
      "destination": "https://tfjshandsignmodel.s3.jp-tok.cloud-object-storage.appdomain.cloud/model.json"
    }
  ]
}
